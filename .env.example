# ============================================
# ГрузПоток - Пример конфигурации окружения
# ============================================

# ========== БАЗА ДАННЫХ ==========
DATABASE_URL=sqlite:///./gruzpotok.db

# ========== БЕЗОПАСНОСТЬ ==========
SECRET_KEY=change_me_secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ========== ПРИЛОЖЕНИЕ ==========
PROJECT_NAME=ГрузПоток
APP_NAME=ГрузПоток
APP_VERSION=1.0.0
DEBUG=false
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:8080

# ========== AI / LLM ==========
AI_USE_LLM=false
AI_FALLBACK_TO_LOCAL=true
AI_TIMEOUT_SECONDS=30

# ========== Hybrid AI Router (Ollama + VPS Fallback) ==========
LOCAL_OLLAMA_URL=http://localhost:11434
LOCAL_MODEL=llama3:8b
VPS_AI_URL=https://ai.yourdomain.com/generate
VPS_MODEL=mistral
AI_TIMEOUT=10

# ========== AI antifraud ==========
MIN_RATE_PER_KM=35
MAX_RATE_PER_KM=200
LOW_TRUST_SCORE_THRESHOLD=40
AI_ANTIFRAUD_ENABLE_LLM=false
AI_ANTIFRAUD_LLM_MODEL=llama3:8b
ROUTE_RATE_CACHE_TTL_SEC=600
ROUTE_RATE_FALLBACK_MIN=35
ROUTE_RATE_FALLBACK_MAX=200
ROUTE_RATE_TIER_MAP_JSON={"short":{"max_km":300,"min":40,"max":220},"mid":{"max_km":1200,"min":35,"max":200},"long":{"max_km":100000,"min":30,"max":180}}
ANTIFRAUD_STRICT_MODE=true
ANTIFRAUD_DOCS_ENABLE=true

# ========== OpenAI ==========
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ========== Yandex GPT ==========
YANDEX_GPT_KEY=
YANDEX_FOLDER_ID=

# ========== GigaChat ==========
GIGACHAT_KEY=

# ========== Single Organism Sync (gruzpotok-api <-> tg-bot) ==========
INTERNAL_TOKEN=change_me_internal_token
TG_BOT_URL=http://tg-bot:8001
TG_BOT_INTERNAL_URL=http://tg-bot:8001
TG_BOT_INTERNAL_EVENT_PATH=/internal/event
PUBLIC_BASE_URL=http://144.31.64.130:8000
LOGIN_TOKEN_TTL_SECONDS=300
MAGIC_LINK_TTL_SECONDS=300
SYNC_WARMUP_TTL_SEC=600
