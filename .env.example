# Токен того бота, который реально запускаешь (от @BotFather)
BOT_TOKEN=CHANGE_ME
BOT_USERNAME=your_bot_username
REDIS_URL=redis://redis:6379
DATABASE_URL=postgresql+asyncpg://bot:botpass@gtm-postgres:5432/botdb
# Твой Telegram user_id — сюда приходят алерты Watchdog (не чаще раза в 15 мин)
ADMIN_ID=123456789
DEBUG=false
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me
SECRET_KEY=change_me
# Публичный URL приложения для WebApp (например https://yourdomain.com)
WEBAPP_URL=
TELEGRAM_TMA_MAX_AGE_SEC=86400
GEO_HTTP_TIMEOUT_SEC=5
GEO_NOMINATIM_URL=https://nominatim.openstreetmap.org/search
GEO_OSRM_URL=https://router.project-osrm.org/route/v1/driving
GEO_USER_AGENT=GoTruck_AI_Bot/1.0
# Ключ Groq API для умного поиска /find и AI (опционально)
# GROQ_API_KEY=
# OpenAI API ключ (альтернатива Groq для LLM-парсера)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Hybrid AI Router (Ollama -> VPS fallback)
LOCAL_OLLAMA_URL=http://localhost:11434
LOCAL_MODEL=llama3:8b
VPS_AI_URL=https://ai.yourdomain.com/generate
VPS_MODEL=mistral
AI_TIMEOUT=10

# Antifraud v2
MIN_RATE_PER_KM=35
MAX_RATE_PER_KM=200
LOW_TRUST_SCORE_THRESHOLD=40
AI_ANTIFRAUD_ENABLE_LLM=false
AI_ANTIFRAUD_LLM_MODEL=llama3:8b
ROUTE_RATE_CACHE_TTL_SEC=600
ROUTE_RATE_FALLBACK_MIN=35
ROUTE_RATE_FALLBACK_MAX=200
ROUTE_RATE_TIER_MAP_JSON={"short":{"max_km":300,"min":40,"max":220},"mid":{"max_km":1200,"min":35,"max":200},"long":{"max_km":100000,"min":30,"max":180}}
ANTIFRAUD_STRICT_MODE=true
ANTIFRAUD_DOCS_ENABLE=true

# Cross-service sync (tg-bot <-> gruzpotok-api)
INTERNAL_TOKEN=change_me_internal_token
INTERNAL_API_TOKEN=change_me_internal_token
INTERNAL_HTTP_TIMEOUT=10
TG_BOT_INTERNAL_URL=http://tg-bot:8000
GRUZPOTOK_API_INTERNAL_URL=http://gruzpotok-api:8000
GRUZPOTOK_PUBLIC_URL=http://144.31.64.130:8000
GRUZPOTOK_SYNC_PATH=/internal/sync
GRUZPOTOK_VERIFY_LOGIN_PATH=/internal/auth/verify-login-token
GRUZPOTOK_CREATE_MAGIC_LINK_PATH=/internal/auth/create-login-token
GRUZPOTOK_CREATE_LOGIN_PATH=/internal/auth/create-login-token

# Parser-bot (Telegram userbot -> gruzpotok-api sync)
PARSER_ENABLED=false
PARSER_TG_API_ID=
PARSER_TG_API_HASH=
# Рекомендуется StringSession для headless Docker
PARSER_TG_STRING_SESSION=
PARSER_TG_SESSION_NAME=/app/.parser/parser-bot
# Список чатов: @username,-1001234567890,@another_channel
PARSER_CHAT_IDS=
PARSER_KEYWORDS=груз,погрузка,выгрузка,тент,реф,ндс,ставка,догруз,фрахт
PARSER_DEDUPE_TTL_SEC=7200
PARSER_SOURCE_NAME=tg-parser-bot
PARSER_DEFAULT_USER_ID=
PARSER_HTTP_TIMEOUT=10
PARSER_STREAM_NAME=logistics_stream
PARSER_STREAM_MAXLEN=200000
PARSER_STREAM_GROUP=parser_workers
PARSER_STREAM_BLOCK_MS=1000
PARSER_STREAM_BATCH=100
PARSER_STREAM_CLAIM_IDLE_MS=60000
PARSER_STARTUP_BACKFILL_LIMIT=10
PARSER_STARTUP_BACKFILL_MINUTES=30
PARSER_HEARTBEAT_KEY=parser:heartbeat
PARSER_HEARTBEAT_TTL_SEC=900
PARSER_SELF_KILL_AFTER_SEC=600
PARSER_SELF_KILL_GRACE_SEC=300
PARSER_WORKER_NAME=worker-1
PARSER_WORKER_MAX_RETRIES=3
PARSER_MANUAL_REVIEW_ALERT_THRESHOLD=20
AVITO_ENABLED=false
AVITO_POLL_INTERVAL_MIN=15
AVITO_MAX_PAGES_PER_RUN=3
AVITO_SEARCH_URL=
AVITO_TRUCKS_URL=
AVITO_INTERVAL_SEC=300
AVITO_MAX_ADS=50
AVITO_STATE_FILE=avito_state.json
VK_ENABLED=false
VK_ACCESS_TOKEN=
VK_GROUP_IDS=
VK_POLL_INTERVAL_SEC=60
VK_FETCH_COUNT=5
VK_DEDUPE_TTL_SEC=86400
VK_API_VERSION=5.199
VK_SOURCE_NAME=vk-parser-bot
# LLM-based smart parser (requires GROQ_API_KEY)
PARSER_USE_LLM=false
# Источник эталонных цен по маршрутам (например @umnayalogistika)
PARSER_PRICE_SOURCE_CHAT=
PARSER_PRICE_REFERENCE_DAYS=14
PARSER_PRICE_REFERENCE_MIN_SAMPLES=2
PARSER_MAX_RATE_RUB=5000000
PARSER_MAX_RATE_PER_KM=500
PARSER_RATE_RECHECK_WITH_LLM=false
PARSER_SCORE_MIN_TRUST=40
PARSER_SCORING_ENABLE_AI=false
PARSER_SCORING_AI_MODEL=
PARSER_SCORING_TIMEOUT_SEC=8
DADATA_API_URL=https://suggestions.dadata.ru/suggestions/api/4_1/rs/findById/party
DADATA_API_TOKEN=

# Premium (Telegram Stars)
PREMIUM_STARS_7D=700
PREMIUM_STARS_30D=2400
TRUCK_CONTACT_UNLOCK_STARS=190
REFERRAL_REWARD_DAYS=7
REFERRAL_INVITED_REWARD_DAYS=3
REFERRAL_AMBASSADOR_THRESHOLD=10
MANUAL_CARGO_NOTIFY_DEDUPE_SEC=300
ADMIN_NOTIFICATION_MUTE_SEC=86400

# Escrow prototype
ESCROW_ENABLED=true
# mock | tochka
ESCROW_PROVIDER=mock
ESCROW_PLATFORM_FEE_PERCENT=2.0
ESCROW_FAST_PAYOUT_FEE_PERCENT=0.5
TOCHKA_CLIENT_ID=
TOCHKA_CLIENT_SECRET=
TOCHKA_BASE_URL=https://enter.tochka.com/api/v2
